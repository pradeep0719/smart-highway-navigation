# Docker Compose deployment variables
# Copy to deploy/.env before running: docker compose up -d --build

# Public URL (used for CORS — must match how users access the app)
CLIENT_URL=http://localhost

# Host port for the web container (nginx)
HTTP_PORT=80

# --- JWT (REQUIRED: change in production) ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=30d

# --- Google Maps (optional) ---
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# --- OpenStreetMap services ---
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# --- Admin seed (created on first API startup) ---
ADMIN_EMAIL=admin@smarthighway.local
ADMIN_PASSWORD=change-me-in-production

# --- Frontend build ---
VITE_APP_NAME=Smart Highway Navigation
