# =============================================================================
# Smart Highway Navigation - Root Environment Variables
# Copy to .env and fill in values for local development / deployment
# =============================================================================

# --- Application ---
NODE_ENV=development
APP_NAME=Smart Highway Navigation
APP_URL=http://localhost:5173
API_URL=http://localhost:5000/api

# --- Backend Server ---
PORT=5000
CLIENT_URL=http://localhost:5173

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/smart-highway-nav

# --- JWT Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# --- Google Maps API ---
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- OpenStreetMap / Routing ---
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# --- Admin (seed) ---
ADMIN_EMAIL=admin@smarthighway.local
ADMIN_PASSWORD=change-me-in-production

# =============================================================================
# Docker deployment — copy deploy/.env.example to deploy/.env instead
# See deploy/README.md for: make deploy | docker compose up -d --build
# =============================================================================
# HTTP_PORT=80
# CLIENT_URL=http://localhost
